---
import { siteConfig } from "../../config";
import TechProject from "./pointcloud.astro";
import ThesisProject from "./WaTOD.astro";

export async function getStaticPaths() {
  return siteConfig.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

{project.type === "tech" ? (
  <TechProject project={project} />
) : (
  <ThesisProject project={project} />
)}