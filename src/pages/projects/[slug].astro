---
import { siteConfig } from "../../config";
import TechProject from "../../layouts/projects/pointcloud.astro";
import ThesisProject from "../../layouts/projects/WaTOD.astro";
import TransitDelhi from "../../layouts/projects/transit-delhi.astro";

export async function getStaticPaths() {
  return siteConfig.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

{project.type === "tech" ? (
  <TechProject project={project} />
) : project.type === "TransitDelhi" ? (
  <TransitDelhi project={project} />
) : (
  <ThesisProject project={project} />
)}