---
import { siteConfig } from "../../config";
import "../../styles/global.css";

const { project } = Astro.props;

type ResultVisual = {
  src: string;
  caption: string;
};

// ✅ typed variables (fix all errors)
const methodology: string[] = project.methodology ?? [];
const data: string[] = project.data ?? [];
const process: string[] = project.process ?? [];
const analysis: string[] = project.analysis ?? [];
const discussion: string[] = project.discussion ?? [];
const results: string[] = project.results ?? [];

const summaryVisuals: string[] = project.summaryVisuals ?? [];
const contextVisuals: string[] = project.contextVisuals ?? [];
const objectiveVisuals: string[] = project.objectiveVisuals ?? [];
const methodologyVisuals: string[] = project.methodologyVisuals ?? [];
const processVisuals: string[] = project.processVisuals ?? [];
const analysisVisuals: string[] = project.analysisVisuals ?? [];
const discussionVisuals: string[] = project.discussionVisuals ?? [];

const resultVisuals: ResultVisual[] = project.resultVisuals ?? [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={project.description} />
    <title>{project.name} | {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-900">
    <main class="min-h-screen">
      <section class="px-8 sm:px-12 md:px-16 lg:px-24 pt-8 sm:pt-10 md:pt-12 pb-16">
        <div class="max-w-7xl mx-auto">
          <a
            href="/#projects"
            class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition"
          >
            <span>←</span>
            <span>Back to projects</span>
          </a>

          <div class="mt-10 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
            <div class="lg:col-span-5">
              <p
                class="text-sm font-mono mb-4"
                style={`color: ${siteConfig.accentColor}`}
              >
                Project
              </p>

              <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.05] tracking-tight">
                {project.name}
              </h1>

              <p class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed max-w-xl">
                {project.description}
              </p>

              {project.skills?.length ? (
                <div class="flex flex-wrap gap-2 mt-8">
                  {project.skills.map((skill: string) => (
                    <span class="text-sm text-gray-700 border border-gray-200 rounded-full px-3 py-1.5">
                      {skill}
                    </span>
                  ))}
                </div>
              ) : null}
            </div>

            <div class="lg:col-span-7">
              {project.cover ? (
                <figure class="space-y-3">
                  <button
                    type="button"
                    class="w-full rounded-2xl overflow-hidden bg-white border border-gray-200 cursor-zoom-in"
                    data-lightbox-src={project.cover}
                    data-lightbox-alt={project.name}
                  >
                    <img
                      src={project.cover}
                      alt={project.name}
                      class="w-full h-auto object-contain"
                    />
                  </button>
                </figure>
              ) : (
                <div class="w-full aspect-[16/10] rounded-2xl bg-gray-100 flex items-center justify-center text-gray-400">
                  Add cover image
                </div>
              )}
            </div>
          </div>
        </div>
      </section>

      <section class="px-8 sm:px-12 md:px-16 lg:px-24 pb-20">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
          <aside class="lg:col-span-3">
            <div class="lg:sticky lg:top-10">
              {project.link ? (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-medium text-gray-900 hover:text-gray-600 transition"
                >
                  <span>Open project</span>
                  <span>↗</span>
                </a>
              ) : null}
            </div>
          </aside>

          <div class="lg:col-span-9">
            <div class="space-y-16">
              {project.summary ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Overview
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      <p class="text-lg sm:text-xl text-gray-800 leading-relaxed max-w-3xl">
                        {project.summary}
                      </p>

                      {summaryVisuals.length ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                          {summaryVisuals.map((img) => (
                            <button
                              type="button"
                              class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                              data-lightbox-src={img}
                              data-lightbox-alt={`${project.name} summary visual`}
                            >
                              <img
                                src={img}
                                alt={`${project.name} summary visual`}
                                class="w-full h-auto object-contain rounded-xl"
                              />
                            </button>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}

              {project.context ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Context
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      <p class="text-base sm:text-lg text-gray-700 leading-relaxed max-w-3xl">
                        {project.context}
                      </p>

                      {contextVisuals.length ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                          {contextVisuals.map((img) => (
                            <button
                              type="button"
                              class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                              data-lightbox-src={img}
                              data-lightbox-alt={`${project.name} context visual`}
                            >
                              <img
                                src={img}
                                alt={`${project.name} context visual`}
                                class="w-full h-auto object-contain rounded-xl"
                              />
                            </button>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}

              {project.objective ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Objective
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      <p class="text-base sm:text-lg text-gray-700 leading-relaxed max-w-3xl">
                        {project.objective}
                      </p>

                      {objectiveVisuals.length ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                          {objectiveVisuals.map((img) => (
                            <button
                              type="button"
                              class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                              data-lightbox-src={img}
                              data-lightbox-alt={`${project.name} objective visual`}
                            >
                              <img
                                src={img}
                                alt={`${project.name} objective visual`}
                                class="w-full h-auto object-contain rounded-xl"
                              />
                            </button>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}

              {methodology?.length ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Method
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6">
                        {methodology.map((item, i) => (
                          <div>
                            <p
                              class="text-sm font-mono mb-2"
                              style={`color: ${siteConfig.accentColor}`}
                            >
                              0{i + 1}
                            </p>
                            <p class="text-gray-700 leading-relaxed">{item}</p>
                          </div>
                        ))}
                      </div>

                      {methodologyVisuals.length ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                          {methodologyVisuals.map((img) => (
                            <button
                              type="button"
                              class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                              data-lightbox-src={img}
                              data-lightbox-alt={`${project.name} methodology visual`}
                            >
                              <img
                                src={img}
                                alt={`${project.name} methodology visual`}
                                class="w-full h-auto object-contain rounded-xl"
                              />
                            </button>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}

              {project.data?.length ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Data
                      </h2>
                    </div>
                    <div class="md:col-span-9">
                      <ul class="space-y-4 max-w-3xl list-disc pl-5">
                        {data.map((item) => (
                          <li class="text-gray-700 leading-relaxed">{item}</li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </section>
              ) : null}

              {project.process?.length ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Process
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      <ul class="space-y-4 max-w-3xl list-disc pl-5">
                        {process.map((item) => (
                          <li class="text-gray-700 leading-relaxed">{item}</li>
                        ))}
                      </ul>

                      {processVisuals.length ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                          {processVisuals.map((img) => (
                            <button
                              type="button"
                              class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                              data-lightbox-src={img}
                              data-lightbox-alt={`${project.name} process visual`}
                            >
                              <img
                                src={img}
                                alt={`${project.name} process visual`}
                                class="w-full h-auto object-contain rounded-xl"
                              />
                            </button>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}

              {project.analysis?.length ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Analysis
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      <ul class="space-y-4 max-w-3xl list-disc pl-5">
                        {analysis.map((item) => (
                          <li class="text-gray-700 leading-relaxed">{item}</li>
                        ))}
                      </ul>

                      {analysisVisuals.length ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                          {analysisVisuals.map((img) => (
                            <button
                              type="button"
                              class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                              data-lightbox-src={img}
                              data-lightbox-alt={`${project.name} analysis visual`}
                            >
                              <img
                                src={img}
                                alt={`${project.name} analysis visual`}
                                class="w-full h-auto object-contain rounded-xl"
                              />
                            </button>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}

              {(project.results?.length || resultVisuals.length) ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Results
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      {project.results?.length ? (
                        <ul class="space-y-4 max-w-3xl list-disc pl-5">
                          {results.map((item) => (
                            <li class="text-gray-700 leading-relaxed">{item}</li>
                          ))}
                        </ul>
                      ) : null}

                      {resultVisuals.length ? (
                        <div class="space-y-10">
                          {resultVisuals.map((item) => (
                            <figure class="space-y-3">
                              <button
                                type="button"
                                class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                                data-lightbox-src={item.src}
                                data-lightbox-alt={`${project.name} result visual`}
                              >
                                <img
                                  src={item.src}
                                  alt={`${project.name} result visual`}
                                  class="w-full h-auto object-contain rounded-xl"
                                />
                              </button>
                              <figcaption class="text-sm text-gray-600 max-w-3xl leading-relaxed border-l-2 border-gray-300 pl-4">
                                {item.caption}
                              </figcaption>
                            </figure>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}

              {project.discussion?.length ? (
                <section class="border-t border-gray-200 pt-8">
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <div class="md:col-span-3">
                      <h2 class="text-sm font-mono uppercase tracking-wide text-gray-500">
                        Discussion
                      </h2>
                    </div>
                    <div class="md:col-span-9 space-y-6">
                      <ul class="space-y-4 max-w-3xl list-disc pl-5">
                        {discussion.map((item) => (
                          <li class="text-gray-700 leading-relaxed">{item}</li>
                        ))}
                      </ul>

                      {discussionVisuals.length ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                          {discussionVisuals.map((img) => (
                            <button
                              type="button"
                              class="w-full bg-white border border-gray-200 rounded-2xl p-4 cursor-zoom-in"
                              data-lightbox-src={img}
                              data-lightbox-alt={`${project.name} discussion visual`}
                            >
                              <img
                                src={img}
                                alt={`${project.name} discussion visual`}
                                class="w-full h-auto object-contain rounded-xl"
                              />
                            </button>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                </section>
              ) : null}
            </div>
          </div>
        </div>
      </section>
    </main>

    <div
      id="lightbox"
      class="fixed inset-0 z-50 hidden bg-black/80 p-4 sm:p-8"
      aria-hidden="true"
    >
      <div class="relative flex h-full w-full items-center justify-center">
        <button
          id="lightbox-close"
          type="button"
          class="absolute right-2 top-2 sm:right-4 sm:top-4 flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-white text-2xl leading-none hover:bg-white/20 transition"
          aria-label="Close image"
        >
          ×
        </button>

        <img
          id="lightbox-image"
          src=""
          alt=""
          class="max-h-full max-w-full object-contain rounded-xl"
        />
      </div>
    </div>

    <script is:inline>
      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");
      const triggers = document.querySelectorAll("[data-lightbox-src]");

      const openLightbox = (src, alt) => {
        lightboxImage.src = src;
        lightboxImage.alt = alt || "";
        lightbox.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");
        lightbox.setAttribute("aria-hidden", "false");
      };

      const closeLightbox = () => {
        lightbox.classList.add("hidden");
        lightboxImage.src = "";
        lightboxImage.alt = "";
        document.body.classList.remove("overflow-hidden");
        lightbox.setAttribute("aria-hidden", "true");
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          openLightbox(
            trigger.getAttribute("data-lightbox-src"),
            trigger.getAttribute("data-lightbox-alt")
          );
        });
      });

      lightboxClose?.addEventListener("click", closeLightbox);

      lightbox?.addEventListener("click", (event) => {
        if (event.target === lightbox) closeLightbox();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !lightbox.classList.contains("hidden")) {
          closeLightbox();
        }
      });
    </script>
  </body>
</html>